<Window x:Class="SoundSwitcher.Views.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayMenu"
        Width="180"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    <Border x:Name="MenuBorder"
            CornerRadius="10"
            Padding="6"
            BorderThickness="1">
        <StackPanel>
            <Button x:Name="SettingsButton"
                    Height="30"
                    Margin="0,0,0,4"
                    HorizontalContentAlignment="Left"
                    Padding="10,0,10,0"
                    Click="OnSettingsClicked"
                    Content="Settings" />
            <Button x:Name="ExitButton"
                    Height="30"
                    HorizontalContentAlignment="Left"
                    Padding="10,0,10,0"
                    Click="OnExitClicked"
                    Content="Exit" />
        </StackPanel>
    </Border>
</Window>
