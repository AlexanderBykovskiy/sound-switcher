<Window x:Class="SoundSwitcher.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sound Switcher - Settings"
        Icon="pack://application:,,,/Assets/app-icon.png"
        Height="300"
        Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="14"
                   FontWeight="SemiBold"
                   Text="Tray icon and device settings" />

        <ListView Grid.Row="1"
                  Margin="0,12,0,12"
                  ItemsSource="{Binding Devices}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Content="{Binding Name}" />

                        <ComboBox Grid.Column="1"
                                  MinWidth="300"
                                  Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding DataContext.DeviceIconOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding IconKind, Mode=TwoWay}">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ComboBox.Resources>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Width="22"
                                               Height="22"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Source="{Binding Preview}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding Label}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="90"
                    Margin="0,0,8,0"
                    Click="OnCancelClicked"
                    Content="Cancel" />
            <Button Width="90"
                    IsDefault="True"
                    Click="OnSaveClicked"
                    Content="Save" />
        </StackPanel>
    </Grid>
</Window>
